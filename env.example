# Platform-Agnostic Futures Trading Bot Configuration
# Copy this file to .env and fill in your credentials

# =============================================================================
# PLATFORM SELECTION
# =============================================================================
# Choose your trading platform: binance, tradovate, tradovate_ui or ninjatrader
TRADING_PLATFORM=tradovate_ui

# =============================================================================
# BINANCE CONFIGURATION
# =============================================================================
# Binance Futures API credentials
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# =============================================================================
# TRADOVATE CONFIGURATION
# =============================================================================
# Tradovate API credentials
TRADOVATE_USERNAME=charlie***
TRADOVATE_PASSWORD=****
TRADOVATE_APP_ID=your_app_id
TRADOVATE_APP_VERSION=your_app_version
TRADOVATE_CID=your_client_id
TRADOVATE_SEC=your_secret
TRADOVATE_DEMO=true
TRADOVATE_BASE_URL=https://trader.tradovate.com

TRADOVATE_USER=charlie****
TRADOVATE_PASSWORD=****

# =============================================================================
# NINJATRADER CONFIGURATION
# =============================================================================
# NinjaTrader API configuration
NINJATRADER_API_URL=http://localhost:8080
NINJATRADER_API_KEY=your_ninjatrader_api_key
NINJATRADER_SIMULATION=true

# =============================================================================
# TRADING CONFIGURATION
# =============================================================================
# Default trading symbol (ES for S&P 500 futures, NQ for Nasdaq futures)
# DEFAULT_SYMBOL=ES
DEFAULT_QUANTITY=1.0
MAX_POSITION_SIZE=1.0

# =============================================================================
# RISK MANAGEMENT
# =============================================================================
MAX_DAILY_LOSS=500.0
MAX_DAILY_PROFIT=1000 
MAX_DRAWDOWN_PERCENT=5.0
STOP_LOSS_PERCENT=2.0
STOP_LOSS_PERCENTAGE=2.0
TAKE_PROFIT_PERCENT=4.0
TAKE_PROFIT_PERCENTAGE=4.0

# =============================================================================
# OPENING RANGE STRATEGY
# =============================================================================
OPENING_RANGE_MINUTES=30
BREAKOUT_THRESHOLD_PERCENT=0.05
BREAKOUT_POINTS=2.0
MIN_MOVE_FROM_OR=1.5
MIN_RANGE_SIZE=0.001
VOLUME_CONFIRMATION=true
PROFIT_TARGET_MULTIPLIER=2.0
STOP_LOSS_MULTIPLIER=2.0

# =============================================================================
# EXIT POINTS (Fixed mode)
# 1 point = $50 per ES contract
# 1 tick = 0.25 points = $12.50
# =============================================================================
STOP_LOSS_POINTS=4.0
TAKE_PROFIT_POINTS=6.0

# ============================================================
# ADAPTIVE STOP BASE VALUES (used when volatility-adaptive mode is active)
# These are the MINIMUM stops — volatility can widen them
# ============================================================
STOP_LOSS_BASE_POINTS=6.0    # Never tighter than 4 points
TAKE_PROFIT_BASE_POINTS=10.0  # Never tighter than 6 points
MIN_STOP_LOSS_POINTS=4.0               # Never tighter than 2pts
MAX_STOP_LOSS_POINTS=15.0              # Never wider than 12pts
MIN_TAKE_PROFIT_POINTS=8.0             # Min take profit
MAX_TAKE_PROFIT_POINTS=25.0            # Max take profit

# =============================================================================
# BOT CONTROL
# =============================================================================
TRADING_ENABLED=true
COOLDOWN_MINUTES=5
MAX_OPEN_POSITIONS=3

# ============================================================
# RISK LIMITS (verify or adjust for your testing)
# ============================================================
MAX_DAILY_TRADES=10          # Conservative during testing (was 10)
COOLDOWN_PERIOD=300          # 5 min cooldown after a loss


# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL=sqlite:///trading_bot.db
SUPABASE_URL=supabase_url
SUPABASE_KEY=supabase_key

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=trading_bot.log

FIXTURE=tradovate_dashboard.html
BROWSER_MODE=cdp
HEADLESS=0
BROWSER_TIMEOUT_MS=20000
DRY_RUN=false

PW_MODE=cdp
CDP_URL=http://localhost:9222

# -------------------------------------------------------------------
# ORB BREAK+RETEST STRATEGY (Cousin's - Primary Morning Strategy)
# -------------------------------------------------------------------
ORB_RETEST_OR_MINUTES=30               # 9:30-9:45 AM ET opening range
ORB_RETEST_BREAKOUT_PTS=2.0            # Points beyond OR to confirm breakout
ORB_RETEST_BREAKOUT_PCT=0.0            # 0% (disabled, using points only)
ORB_RETEST_TOLERANCE=1.0               # Retest must get within 1pt of OR level
ORB_RETEST_MAX_STOP=10.0               # Max 10pts stop (MES = $50 risk)
ORB_RETEST_MIN_GAP_SEC=30.0            # 30 sec cooldown between signals
ORB_RETEST_MAX_TRADES=4                # Max # trades per day (discipline)
ORB_RETEST_ONE_SIDE=true               # Prevents whipsaw (one direction only)
ORB_RETEST_START=9,30                  # Start trading at 9:45 AM ET
ORB_RETEST_END=10,30                   # Stop trading at 12:00 PM ET
ORB_RETEST_USE_SMA=true                # Use SMA20/200 trend filter
ORB_RETEST_SMA_TF=5m                   # Calculate SMAs on 5m timeframe

# -------------------------------------------------------------------
# VOLUME TRACKING
# -------------------------------------------------------------------
VOLUME_LOOKBACK_BARS=20                # Bars to analyze for volume profile
HIGH_VOLUME_THRESHOLD=1.5              # >1.5x avg = high volume
LOW_VOLUME_THRESHOLD=0.5               # <0.5x avg = low volume

# -------------------------------------------------------------------
# TIME WINDOWS (All times in US Eastern)
# -------------------------------------------------------------------
TRADING_START_HOUR=9
TRADING_START_MINUTE=0
TRADING_END_HOUR=16
TRADING_END_MINUTE=0

# -------------------------------------------------------------------
# DATA MANAGEMENT
# -------------------------------------------------------------------
KEEP_BARS=480                          # Keep 480 minutes = 8 hours of data
DATA_REFRESH_INTERVAL=1.0              # Refresh data every 1 second

# -------------------------------------------------------------------
# LOGGING
# -------------------------------------------------------------------
LOG_LEVEL=INFO                         # DEBUG, INFO, WARNING, ERROR
LOG_FILE=trading_bot.log
LOG_MAX_SIZE=10485760                  # 10MB
LOG_BACKUP_COUNT=5

# -------------------------------------------------------------------
# PAPER TRADING / SIMULATION
# -------------------------------------------------------------------
PAPER_TRADING=true                     # Set to false for live trading
PAPER_STARTING_BALANCE=10000
PAPER_COMMISSION_PER_SIDE=0.62         # MES commission

# Mean Reversion Strategy (Afternoon Session)
MEAN_REVERSION_LOOKBACK = 20  # Bollinger Bands period
MEAN_REVERSION_STD_DEV = 2.0  # BB standard deviations
MEAN_REVERSION_MAX_TRADES = 4  # Max trades per day
MEAN_REVERSION_MIN_BANDWIDTH = 0.0025 # 0.25% minimum range
MEAN_REVERSION_COOLDOWN_BARS = 3 # Wait 3 bars between trades
MEAN_REVERSION_REQUIRE_CONFIRMATION = True # Wait for re-entry 

# -------------------------------------------------------------------
# RECOMMENDED SETTINGS FOR MES (Micro E-mini S&P 500)
# -------------------------------------------------------------------
# MES tick value = $1.25 per 0.25 point move
# 1 point = $5.00
# 2 points = $10.00
# 4 points = $20.00
# 10 points = $50.00
#
# Conservative risk per trade: $50-100 (10-20 points)
# Aggressive risk per trade: $100-200 (20-40 points)
#
# For ORB Retest:
# - MAX_STOP=10pts = $50 risk per trade
# - If you have $10,000 account = 0.5% risk per trade ✓
# - Max 2 trades/day = max $100 risk/day = 1% daily risk ✓
#
# For Simple OR:
# - BREAKOUT_POINTS=2pts = 2pt buffer beyond OR
# - MIN_MOVE=1.5pts = filters tiny moves
# - STOP_LOSS=4pts = $20 risk (tight)

# ===================================================================
# NOTES
# ===================================================================
#
# Strategy Selection Priority (Time-Based):
# 9:30-12:00 ET  → ORB Retest (primary)
# 9:00-11:00 ET  → Simple OR (backup if ORB hasn't fired)
# Future: Add Momentum, Mean Reversion, Power Hour
#
# Volume Requirements:
# - High volume breakouts = 1.5x average
# - Low volume = reject signal (0.5x average)
#
# Timezone Handling:
# - All times internally converted to US Eastern
# - Make sure system TZ is set: export TZ="America/New_York"
#
# ===================================================================