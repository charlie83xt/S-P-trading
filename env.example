# Futures Trading Bot Configuration

# =============================================================================
# PLATFORM SELECTION
# =============================================================================
# Choose your trading platform: binance, tradovate, or ninjatrader
TRADING_PLATFORM=binance

# Default trading symbol
DEFAULT_SYMBOL=BTCUSDT

# =============================================================================
# BINANCE CONFIGURATION (for crypto futures)
# =============================================================================
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
BINANCE_TESTNET=true

# =============================================================================
# TRADOVATE CONFIGURATION (for S&P 500 and other traditional futures)
# =============================================================================
TRADOVATE_USERNAME=your_tradovate_username
TRADOVATE_PASSWORD=your_tradovate_password
TRADOVATE_DEMO=true

# =============================================================================
# NINJATRADER CONFIGURATION (for traditional futures with simulation)
# =============================================================================
NINJATRADER_API_URL=http://localhost:8080
NINJATRADER_SIMULATION=true

# =============================================================================
# TRADING STRATEGY SETTINGS
# =============================================================================
# Opening range strategy settings
OPENING_RANGE_MINUTES=30
BREAKOUT_THRESHOLD_PERCENT=0.1

# =============================================================================
# RISK MANAGEMENT SETTINGS
# =============================================================================
# Maximum position size as percentage of account balance (0.1 = 10%)
MAX_POSITION_SIZE=0.1

# Stop loss percentage (2.0 = 2%)
STOP_LOSS_PERCENTAGE=2.0

# Take profit percentage (4.0 = 4%)
TAKE_PROFIT_PERCENTAGE=4.0

# Maximum number of trades per day
MAX_DAILY_TRADES=10

# Cooldown period in seconds after a loss (300 = 5 minutes)
COOLDOWN_PERIOD=300

# =============================================================================
# LOGGING SETTINGS
# =============================================================================
LOG_LEVEL=INFO
LOG_FILE=trading_bot.log

# =============================================================================
# DATABASE SETTINGS
# =============================================================================
DATABASE_URL=sqlite:///trading_bot.db

# =============================================================================
# PLATFORM-SPECIFIC SYMBOL EXAMPLES
# =============================================================================
# For Binance (crypto futures):
# DEFAULT_SYMBOL=BTCUSDT
# DEFAULT_SYMBOL=ETHUSDT
# DEFAULT_SYMBOL=ADAUSDT

# For Tradovate (traditional futures):
# DEFAULT_SYMBOL=ES    # S&P 500 E-mini
# DEFAULT_SYMBOL=NQ    # NASDAQ 100 E-mini
# DEFAULT_SYMBOL=YM    # Dow Jones E-mini

# For NinjaTrader (traditional futures):
# DEFAULT_SYMBOL=ES 12-24    # S&P 500 E-mini December 2024
# DEFAULT_SYMBOL=NQ 12-24    # NASDAQ 100 E-mini December 2024

